# Per-user workspace selection + the resolved gitman config (generated from workspace.defaults.yaml
# via `just configure` / `just resolve`). The committed source of truth is workspace.defaults.yaml.
/workspace.yaml
/gitman.yaml
/gitman.yml
**/__pycache__/
*.pyc
**IsaacLab/
**artifacts/
scripts/.env.wandb
scripts/cluster/*_config
.vscode/
**.venv/
**ilab/
outputs/
scripts/ray/.env.ray
scripts/ray/*job_config*.yaml
resources/
wandb/
worktrees/
logs/

# Local env files with secrets -- commit only the *.template versions
.env
.env.*
!.env.*.template

# HPC Apptainer (.sif) build artifacts
scripts/cluster/exports/
*.sif
*.tar

# Claude working docs (local, not shared)
/CLAUDE.md
/.claude/
